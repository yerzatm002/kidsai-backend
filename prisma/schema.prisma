generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/**
 * ENUMS
 */
enum Role {
  STUDENT
  TEACHER
}

enum TaskType {
  SIMPLE
  DRAG_DROP
  QA
}

enum QuestionType {
  SINGLE
  MULTI
}

/**
 * AUTH CORE
 */
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         Role     @default(STUDENT)
  grade        Int?
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens   RefreshToken[]
  taskAttempts    TaskAttempt[]
  testAttempts    TestAttempt[]
  topicProgress   UserTopicProgress[]
  stats           UserStats?
  userBadges      UserBadge[]
  feedbacks       Feedback[]
  lessonViews   LessonView[]
  aiRequests    AIRequest[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

/**
 * CONTENT CATALOG
 */
model Topic {
  id            String   @id @default(cuid())
  titleKz       String
  titleRu       String
  descriptionKz String
  descriptionRu String
  coverImageUrl String?
  orderIndex    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lessons        Lesson[]
  tasks          Task[]
  test           Test?
  progresses     UserTopicProgress[]

  @@index([orderIndex])
}

model Lesson {
  id          String   @id @default(cuid())
  topicId     String
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  contentKz   String
  contentRu   String

  imageUrl    String?
  videoUrl    String?

  /**
   * attachments: можно хранить массив ссылок/объектов:
   * [{ "type": "pdf", "url": "...", "name": "..." }]
   */
  attachments Json?

  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([topicId, orderIndex])

  lessonViews   LessonView[]
}

/**
 * INTERACTIVE TASKS
 */
model Task {
  id        String   @id @default(cuid())
  topicId   String
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  type      TaskType
  promptKz  String
  promptRu  String

  /**
   * payload: структура зависит от типа задания
   * SIMPLE: { "question": "...", "correct": "..." }
   * DRAG_DROP: { "items":[...], "targets":[...], "mapping":[...] }
   * QA: { "question": "...", "keywords":[...], "rubric": {...} }
   */
  payload   Json
  xpReward  Int      @default(10)

  orderIndex Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attempts  TaskAttempt[]

  @@index([topicId, orderIndex])
}

model TaskAttempt {
  id            String   @id @default(cuid())
  userId        String
  taskId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  /**
   * answerPayload: ответ ученика
   */
  answerPayload Json
  isCorrect     Boolean  @default(false)
  earnedXp      Int      @default(0)

  createdAt     DateTime @default(now())

  @@index([userId, taskId])
  @@index([taskId])
}

/**
 * TESTS
 */
model Test {
  id        String   @id @default(cuid())
  topicId   String   @unique
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions TestQuestion[]
  attempts  TestAttempt[]
}

model TestQuestion {
  id          String       @id @default(cuid())
  testId      String
  test        Test         @relation(fields: [testId], references: [id], onDelete: Cascade)

  type        QuestionType @default(SINGLE)
  questionKz  String
  questionRu  String

  /**
   * options: ["A", "B", "C"] или [{id, label}]
   */
  options     Json

  /**
   * correctAnswer: для SINGLE: {"value":"A"} для MULTI: {"values":["A","C"]}
   */
  correctAnswer Json

  orderIndex  Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([testId, orderIndex])
}

model TestAttempt {
  id        String   @id @default(cuid())
  userId    String
  testId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  test      Test     @relation(fields: [testId], references: [id], onDelete: Cascade)

  /**
   * answers: { "questionId1": {...}, "questionId2": {...} }
   */
  answers   Json
  score     Int      @default(0)
  maxScore  Int      @default(0)

  earnedXp  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId, testId])
  @@index([testId])
}

/**
 * PROGRESS & STATS
 */
model UserTopicProgress {
  id             String   @id @default(cuid())
  userId         String
  topicId        String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic          Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  tasksCompleted Int      @default(0)
  bestTestScore  Int      @default(0)
  completedAt    DateTime?

  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@unique([userId, topicId])
  @@index([topicId])
}

model UserStats {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  totalXp   Int      @default(0)
  level     Int      @default(1)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

/**
 * BADGES (GAMIFICATION)
 */
model Badge {
  id          String   @id @default(cuid())
  code        String   @unique   // например: "FIRST_TASK", "TOP_SCORE", "AI_HELPER"
  titleKz     String
  titleRu     String
  descriptionKz String
  descriptionRu String
  iconUrl     String?
  createdAt   DateTime @default(now())

  userBadges  UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt  DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([badgeId])
}

/**
 * FEEDBACK
 */
model Feedback {
  id        String   @id @default(cuid())
  userId    String
  topicId   String?
  lessonId  String?
  rating    Int?     // 1..5
  message   String
  status    String   @default("NEW") // NEW|IN_REVIEW|DONE (MVP можно просто NEW)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([topicId])
  @@index([createdAt])
}

model LessonView {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model AIRequest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}